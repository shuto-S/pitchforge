# App
NEXT_PUBLIC_APP_NAME=PitchForge
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_AUTH_MODE=password

# Auth
AUTH_MODE=password
# Generate a random value of at least 32 characters and store the production
# value in Secret Manager. Never reuse the judge account password here.
AUTH_SESSION_SECRET=replace-with-production-secret
SESSION_COOKIE_NAME=__Host-pitchforge_session_v2
# Test/local bypass only. The app ignores this in NODE_ENV=production.
AUTH_BYPASS_FOR_TEST=false

# Local auth only. Do not use AUTH_MODE=local in production.
LOCAL_AUTH_UID=local-user
LOCAL_AUTH_EMAIL=local-user@example.test
LOCAL_AUTH_DISPLAY_NAME=Local User
LOCAL_AUTH_SECRET=replace-with-local-only-secret

# AI provider
AI_PROVIDER=auto
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=

# Vertex / Google Cloud mode
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Storage
STORAGE_MODE=gcs
GCS_BUCKET=your-gcs-bucket-name
GCS_API_ENDPOINT=

# Database
DATABASE_MODE=postgres
DATABASE_URL=postgres://user:password@host:5432/database

# BigQuery optional placeholder
BIGQUERY_ENABLED=false
BIGQUERY_DATASET=pitchforge
