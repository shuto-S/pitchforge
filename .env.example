# App
NEXT_PUBLIC_APP_NAME=PitchForge
NEXT_PUBLIC_DEMO_MODE=true

# Identity Platform client config. These are public web app values, but keep real
# values out of the repository.
NEXT_PUBLIC_IDENTITY_PLATFORM_API_KEY=your-identity-platform-web-api-key
NEXT_PUBLIC_IDENTITY_PLATFORM_AUTH_DOMAIN=your-identity-platform-auth-domain
NEXT_PUBLIC_IDENTITY_PLATFORM_PROJECT_ID=your-identity-platform-project-id
NEXT_PUBLIC_IDENTITY_PLATFORM_APP_ID=your-identity-platform-app-id

# Auth
AUTH_ADMIN_EMAILS=admin@example.com
SESSION_COOKIE_NAME=__session
# Test/local bypass only. The app ignores this in NODE_ENV=production.
AUTH_BYPASS_FOR_TEST=false

# AI provider
AI_PROVIDER=auto
GEMINI_MODEL=gemini-flash-latest
GEMINI_API_KEY=

# Vertex / Google Cloud mode
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Storage
STORAGE_MODE=local
GCS_BUCKET=your-gcs-bucket-name

# Firestore
DATASTORE_MODE=local
FIRESTORE_DATABASE_ID=(default)

# Local development only. Keep this ignored by Git.
LOCAL_DATA_DIR=.local-data

# BigQuery optional placeholder
BIGQUERY_ENABLED=false
BIGQUERY_DATASET=pitchforge
